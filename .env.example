# ========================
# La Rosee Backend - Environment Variables
# ========================
# Bu dosyayı kopyalayıp .env olarak kaydedin ve gerçek değerleri girin.

APP_NAME=Rosap API
MONGO_URI=mongodb://localhost:27017
DB_NAME=rosap_db

# 🔐 Güvenlik - openssl rand -hex 32 ile oluşturun
JWT_SECRET=your-strong-secret-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 🤖 OpenAI
OPENAI_API_KEY=sk-your-openai-key

# 🔥 Firebase
FIREBASE_CREDENTIALS_PATH=app/creds/your-firebase-credentials.json
GOOGLE_APPLICATION_CREDENTIALS=creds/your-google-credentials.json

# 📱 Twilio (SMS Doğrulama)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_VERIFY_SID=your-twilio-verify-sid
TWILIO_FROM_NUMBER=+1234567890

# 🌐 API & CORS
API_BASE_URL=http://localhost:8000
# Admin panel ve website URL'lerini virgülle ayırarak girin
CORS_ALLOWED_ORIGINS=https://admin.your-domain.com,https://www.your-domain.com

# 👥 Mümessil e-postaları (virgülle ayırın)
REPRESENTATIVE_EMAILS=personel1@firma.com,personel2@firma.com

# 📄 Google Document AI (Google Cloud Console > Document AI)
DOCAI_PROJECT_ID=your-google-cloud-project-number
DOCAI_LOCATION=us
DOCAI_PROCESSOR_ID=your-document-ai-processor-id
DOCAI_LAYOUT_PROCESSOR_ID=your-document-ai-layout-processor-id
DOCAI_CREDENTIALS_PATH=app/creds/your-google-docai-credentials.json

# 🤖 Groq
GROQ_API_KEY=your-groq-key
